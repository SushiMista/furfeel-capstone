<?xml version="1.0" encoding="utf-8"?>
<!-- Pre-API-21 fallback. Uses the token background rather than a hardcoded
     white so a dark-mode cold start doesn't flash white before Flutter draws
     (drawable-v21 gets the same result via ?android:colorBackground). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_background" />
</layer-list>
